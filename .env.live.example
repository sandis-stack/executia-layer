SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
EXECUTIA_API_KEY=replace-with-strong-key
EXECUTIA_RULES_SOURCE=rpc
ALLOW_SIMULATE=false
EXECUTIA_DEV_MODE=false
NODE_ENV=production
ALLOWED_ORIGIN=https://execution.executia.io

DEFAULT_PROVIDER=webhook
EXECUTIA_REQUIRE_PROVIDER=true
EXECUTIA_PROVIDER_WEBHOOK_URL=https://your-endpoint.example.com/webhook
WEBHOOK_CALLBACK_SECRET=replace-with-strong-secret

EXECUTIA_DB_KEYS_ENABLED=true
EXECUTIA_API_KEYS_JSON=[]
EXECUTIA_OPERATOR_BOOTSTRAP_PASSWORD_HASH=replace-with-password-hash
