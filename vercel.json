{
  "routes": [
    { "src": "^/api/(.*)", "dest": "/api/$1" },

    { "src": "^/dashboard$", "dest": "/dashboard/index.html" },
    { "src": "^/control$", "dest": "/console/operator.html" },
    { "src": "^/history$", "dest": "/console/audit.html" },
    { "src": "^/operations$", "dest": "/console/operations.html" },
    { "src": "^/ops$", "dest": "/console/operations.html" },
    { "src": "^/demo$", "dest": "/demo/index.html" },

    { "src": "^/$", "dest": "/index.html" }
  ]
}
