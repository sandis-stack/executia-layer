{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "^/dashboard$",         "dest": "/dashboard/index.html" },
    { "src": "^/console/(.*)$",      "dest": "/console/$1" },
    { "src": "^/api/v1/(.*)$",       "dest": "/api/v1/$1" }
  ]
}
