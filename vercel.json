{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/v1/execute-event", "dest": "/api/execute-event" },
    { "src": "/api/v1/predict",       "dest": "/api/predict" },
    { "src": "/api/v1/governance",    "dest": "/api/governance" },
    { "src": "/api/v1/health",        "dest": "/api/health" },
    { "src": "/api/v1/generate-rule", "dest": "/api/generate-rule" },
    { "src": "/api/v1/optimize-rules","dest": "/api/optimize-rules" },
    { "src": "/governance",           "dest": "/public/governance.html" },
    { "src": "/dashboard",            "dest": "/public/dashboard.html" },
    { "src": "/",                     "dest": "/public/index.html" }
  ]
}
